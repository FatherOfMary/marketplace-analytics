# ==============================================================================
# Python Environment
# ==============================================================================
# Ignores the local virtual environment folder. This prevents third-party 
# packages from being committed to the repository.
.venv/

# ==============================================================================
# Project Documentation
# ==============================================================================
# Ignores the company profile information AI testing document to ensure 
# internal SOPRA guidelines remain private.
doc/Dokumen Pengujian AI_ Informasi Profil Perusahaan (SOPRA).docx

# ==============================================================================
# Project Data & Artifacts
# ==============================================================================
# Ignores all generated files inside the processed data folder, but keeps the 
# folder structure intact so the pipeline has a place to save outputs.
data/processed/*

# Ignores generated tabular outputs (CSVs).
outputs/tables/*